# Root docker compose secrets — copy to `.env` and fill in.
# Never commit `.env`.

# SQL Server SA password (must meet MSSQL complexity rules)
DB_SA_PASSWORD=ChangeMe_Str0ng!Pass

# Point at the `db` service hostname and the `rms` database (created by db-init)
DATABASE_URL=mssql+aioodbc://sa:ChangeMe_Str0ng!Pass@db:1433/rms?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

JWT_SECRET=replace-with-a-strong-random-secret-min-32-chars

# Optional
APP_ENV=production
LOG_LEVEL=info
RATE_LIMIT_ENABLED=true
ALLOW_SELF_REGISTRATION=true
JWT_REMEMBER_EXPIRE_HOURS=336
NEXT_PUBLIC_ALLOW_SELF_REGISTRATION=true
