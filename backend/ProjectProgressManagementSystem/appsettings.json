{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [ "http://localhost:3000", "http://localhost:5000" ],
  "ConnectionStrings": {
    "Development": "Server=<host>;Database=rms;User ID=<user>;Password=<password>;TrustServerCertificate=true",
    "Stage": "Server=tcp:<stage-server>.database.windows.net,1433;Initial Catalog=rms-stage;Persist Security Info=False;User ID=<user>;Password=<password>;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;",
    "Production": "Server=tcp:<prod-server>.database.windows.net,1433;Initial Catalog=rms-production;Persist Security Info=False;User ID=<user>;Password=<password>;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
  },
  "AppSettings": {
    "JwtSecret": "<replace-with-a-strong-random-secret-min-32-chars>"
  }
}
