# Copy to .env and fill in values — never commit .env

# Database — choose ONE driver block

# PostgreSQL (Render / recommended)
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/rms

# SQL Server (local Docker Compose). Host `db`, database `rms`
# (created by db-init — do not point at `master`). Requires: pip install -e ".[mssql]"
# DATABASE_URL=mssql+aioodbc://user:pass@host:1433/rms?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# MySQL alternative — requires: pip install -e ".[mysql]"
# DATABASE_URL=mysql+aiomysql://user:pass@host:3306/rms

# Security
JWT_SECRET=<replace-with-a-strong-random-secret-min-32-chars>
JWT_ALGORITHM=HS512
JWT_EXPIRE_HOURS=2

# Optional: server-to-server Google exchange (legacy; static Pages UI uses email/password only)
INTERNAL_AUTH_SECRET=

# Defaults for first-time Google sign-ups (Department/Region IntFlag bits)
GOOGLE_DEFAULT_DEPARTMENT=1
GOOGLE_DEFAULT_REGION=1

# CORS — include the GitHub Pages origin in production
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000","https://amulyavarshney.github.io"]

# App
APP_ENV=development
LOG_LEVEL=info
RATE_LIMIT_ENABLED=true
ALLOW_SELF_REGISTRATION=true
JWT_REMEMBER_EXPIRE_HOURS=336

# Optional ESB mail (POST /api/v1/mail) — leave blank to disable
ESB_API_URL=
ESB_SUB_KEY=
ESB_MAIL_FROM=
ESB_MAIL_SENDER=
ESB_MAIL_REPLYTO=
ESB_CALLBACK_POSITIVE_URL=
ESB_CALLBACK_NEGATIVE_URL=
