# Copy to .env and fill in values — never commit .env

# Database — choose ONE driver block

# SQL Server (default)
DATABASE_URL=mssql+aioodbc://user:pass@host:1433/rms?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# PostgreSQL alternative
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/rms

# MySQL alternative
# DATABASE_URL=mysql+aiomysql://user:pass@host:3306/rms

# Security
JWT_SECRET=<replace-with-a-strong-random-secret-min-32-chars>
JWT_ALGORITHM=HS512
JWT_EXPIRE_HOURS=2

# Shared secret with the frontend's Next.js server (NOT the browser) — used
# to authenticate the POST /auth/google server-to-server exchange. Must match
# the frontend's INTERNAL_AUTH_SECRET exactly.
INTERNAL_AUTH_SECRET=<replace-with-a-strong-random-secret>

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# App
APP_ENV=development
LOG_LEVEL=info
