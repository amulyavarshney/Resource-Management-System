{
  "name": "Resource Management System",
  "version": "1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "generate:api": "npm run generate:api:schema && npm run generate:api:types",
    "generate:api:schema": "cd ../backend && python -m scripts.export_openapi > ../frontend/openapi.json",
    "generate:api:types": "openapi-typescript openapi.json -o app/api/generated/openapi.ts"
  },
  "dependencies": {
    "@types/node": "20.4.5",
    "@types/react": "18.2.18",
    "@types/react-dom": "18.2.7",
    "autoprefixer": "10.4.14",
    "axios": "^1.4.0",
    "eslint": "8.46.0",
    "eslint-config-next": "^14.2.3",
    "next": "^14.2.3",
    "postcss": "^8.4.35",
    "react": "^18.3.1",
    "react-datepicker": "^6.2.0",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "tailwindcss": "3.3.3",
    "typescript": "5.1.6",
    "xlsx-js-style": "^1.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "openapi-typescript": "^7.4.4",
    "prettier": "3.0.3"
  }
}
